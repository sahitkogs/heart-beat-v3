# MCP server config — local-only (contains per-session bearer tokens for
# danielealbano/android-remote-control-mcp instances running on emulators).
.mcp.json

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# v3-specific
/junk/
*.apk
*.aab
*.keystore
*.jks

# Release signing — never commit
android/upload-keystore.jks
android/key.properties
key.properties

# Local Play release tooling (downloaded, not source)
/android/bundletool-*.jar

# Play Console service-account key — credential, never commit
/android/play-publisher-key.json
